{
  "name": "drupal-sdc-lsp",
  "version": "0.1.0",
  "description": "Language Server Protocol (LSP) server for Drupal Single Directory Components (SDC) — autocomplete, go-to-definition, and hover docs for Twig templates",
  "keywords": ["drupal", "sdc", "twig", "lsp", "language-server", "single-directory-components", "neovim", "vscode"],
  "license": "MIT",
  "main": "./dist/server.js",
  "bin": {
    "drupal-sdc-lsp": "./dist/server.js"
  },
  "files": ["dist/"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@drupal-sdc-lsp/core": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
